{
  "expo": {
    "name": "Passé Simple",
    "slug": "passe-simple",
    "version": "1.0.0",
    "description": "Révisez la Révolution française avec des fiches, des favoris et des mini-quiz.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "passesimple",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.topalmahmutali.passesimple",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.topalmahmutali.passesimple",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#F6F0E6",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F6F0E6"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
